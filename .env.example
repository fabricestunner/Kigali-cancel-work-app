# Base URL for the backend API. Falls back to the production URL in
# src/services/api.ts when unset, so a deploy with no env var configured
# still points at production.
#
# For local development against a local backend, put your override in
# .env.development.local — NOT .env.local. Vite loads .env.local in every
# mode, including `vite build`, so a localhost value there gets baked into
# a production bundle and breaks every API call on the deployed site.
# .env.development.local applies to `npm run dev` only.
#
# WARNING: every VITE_* value is inlined into the public JavaScript bundle.
# Never put a secret, key, or token in a VITE_* variable.
VITE_API_BASE_URL=https://kcw.enjoyrwanda.rw/api

# Ed25519 PUBLIC key (hex-encoded) used by the /scan ticket scanner to verify
# QR tokens offline. This is public by design — the matching PRIVATE key
# lives on the backend only and must never appear in this repo or in any
# VITE_* variable. Ask backend for the real value once it is generated; the
# scanner treats every token as invalid until this is set.
VITE_TICKET_PUBLIC_KEY=
